[*.fs]
fsharp_space_before_lowercase_invocation = true
fsharp_multiline_block_brackets_on_same_line = true
root = true

[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.{fs,fsi,fsx}]
max_line_length = 120
fsharp_space_before_lowercase_invocation = true
fsharp_multiline_block_brackets_on_same_line = true
fsharp_array_or_list_multiline_formatter = character_width
fsharp_single_line_lambda_with_no_args = true
indent_style = space
indent_size = 4indent_size = 4
